meta {
  name: 1 Create Bucket
  type: http
  seq: 1
}

put {
  url: {{minio_endpoint}}/{{bucket}}
  body: none
  auth: awsv4
}

auth:awsv4 {
  accessKeyId: {{minio_user}}
  secretAccessKey: {{minio_pass}}
  region: us-east-1
  service: s3
}

tests {
  test("bucket created or already exists", function() {
    expect(res.status).to.be.oneOf([200, 409]);
  });
}
