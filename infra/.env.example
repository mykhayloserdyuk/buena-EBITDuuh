# infra/.env.example — copy to .env and fill in values
# Only needed for local operations (docker-compose, mc CLI sync).
# DO NOT commit .env — it is gitignored.

# ── Terraform apply (run locally, never in CI) ──
# Values below are picked up automatically via TF_VAR_* when you source this file.
# gcloud auth application-default login
# source infra/.env && terraform -chdir=infra apply
export TF_VAR_gemini_api_key=""
export TF_VAR_model_provider=""
export TF_VAR_model_name=""
export TF_VAR_mongo_uri=""
export TF_VAR_pat=""
export TF_VAR_ghcr_username==""
export TF_VAR_letsencrypt_email=""